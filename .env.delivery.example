DB_NAME=ljwx_platform
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

POSTGRES_IMAGE=postgres:16.12-alpine
REDIS_IMAGE=redis:7.2.5-alpine

# Use immutable references whenever possible.
# Example tag style: harbor.omniverseai.net/app/ljwx-platform:sha-b7766e9
# Example digest style: harbor.omniverseai.net/app/ljwx-platform@sha256:abc...
BACKEND_IMAGE=harbor.omniverseai.net/app/ljwx-platform:sha-CHANGE_ME
ADMIN_IMAGE=harbor.omniverseai.net/app/ljwx-platform-admin-ui:sha-CHANGE_ME
SCREEN_IMAGE=harbor.omniverseai.net/app/ljwx-platform-screen:sha-CHANGE_ME

BACKEND_PORT=18080
ADMIN_PORT=18081
SCREEN_PORT=18082

SPRING_PROFILES_ACTIVE=prod
ALLOW_WEAK_PASSWORD=0
LJWX_BOOTSTRAP_ADMIN_INITIAL_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
LJWX_BOOTSTRAP_USER_IMPORT_INITIAL_PASSWORD=
