<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ljwx.platform.app.mapper.RptReportDefMapper">

    <resultMap id="ReportDefVOMap" type="com.ljwx.platform.app.vo.report.ReportDefVO">
        <id property="id" column="id"/>
        <result property="reportName" column="report_name"/>
        <result property="reportKey" column="report_key"/>
        <result property="dataSourceType" column="data_source_type"/>
        <result property="queryTemplate" column="query_template"/>
        <result property="columnDef" column="column_def" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="filterDef" column="filter_def" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <select id="selectReportDefList" resultMap="ReportDefVOMap">
        SELECT
            id,
            report_name,
            report_key,
            data_source_type,
            query_template,
            column_def,
            filter_def,
            status,
            remark,
            created_time,
            updated_time
        FROM rpt_report_def
        WHERE deleted = FALSE
        <if test="query.reportName != null and query.reportName != ''">
            AND report_name LIKE CONCAT('%', #{query.reportName}, '%')
        </if>
        <if test="query.reportKey != null and query.reportKey != ''">
            AND report_key = #{query.reportKey}
        </if>
        <if test="query.status != null">
            AND status = #{query.status}
        </if>
        ORDER BY created_time DESC
        <if test="query.pageNum != null and query.pageSize != null">
            LIMIT #{query.pageSize} OFFSET #{query.offset}
        </if>
    </select>

    <select id="countReportDefs" resultType="long">
        SELECT COUNT(*)
        FROM rpt_report_def
        WHERE deleted = FALSE
        <if test="query.reportName != null and query.reportName != ''">
            AND report_name LIKE CONCAT('%', #{query.reportName}, '%')
        </if>
        <if test="query.reportKey != null and query.reportKey != ''">
            AND report_key = #{query.reportKey}
        </if>
        <if test="query.status != null">
            AND status = #{query.status}
        </if>
    </select>

    <select id="selectReportDefById" resultMap="ReportDefVOMap">
        SELECT
            id,
            report_name,
            report_key,
            data_source_type,
            query_template,
            column_def,
            filter_def,
            status,
            remark,
            created_time,
            updated_time
        FROM rpt_report_def
        WHERE id = #{id}
          AND deleted = FALSE
    </select>

    <select id="countByReportKey" resultType="int">
        SELECT COUNT(*)
        FROM rpt_report_def
        WHERE tenant_id = #{tenantId}
          AND report_key = #{reportKey}
          AND deleted = FALSE
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

</mapper>
