<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ljwx.platform.app.mapper.HelpDocMapper">

    <resultMap id="BaseResultMap" type="com.ljwx.platform.app.domain.HelpDoc">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="doc_key" property="docKey"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="category" property="category"/>
        <result column="route_match" property="routeMatch"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="deleted" property="deleted"/>
        <result column="version" property="version"/>
    </resultMap>

    <select id="findByRouteMatch" resultMap="BaseResultMap">
        SELECT *
        FROM sys_help_doc
        WHERE deleted = FALSE
          AND status = 1
          AND (tenant_id = #{tenantId} OR tenant_id = 0)
          AND (
              route_match = #{routePath}
              OR #{routePath} LIKE route_match || '%'
          )
        ORDER BY
            CASE WHEN route_match = #{routePath} THEN 0 ELSE 1 END,
            CASE WHEN tenant_id = #{tenantId} THEN 0 ELSE 1 END,
            sort_order ASC
        LIMIT 1
    </select>

    <select id="listByCategory" resultMap="BaseResultMap">
        SELECT *
        FROM sys_help_doc
        WHERE deleted = FALSE
          AND status = 1
          AND (tenant_id = #{tenantId} OR tenant_id = 0)
          <if test="category != null and category != ''">
              AND category = #{category}
          </if>
        ORDER BY sort_order ASC, created_time DESC
    </select>

</mapper>
