# Service
APP_ENV=prod
LOG_LEVEL=INFO
SQLITE_PATH=/data/sync.db

# Webhook security
SYNC_HMAC_SECRET=replace_me
SYNC_BEARER_TOKEN=replace_me
WEBHOOK_MAX_SKEW_SECONDS=300

# GHCR
GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=replace_me
GHCR_TOKEN=replace_me

# Harbor
HARBOR_REGISTRY=harbor.eu.lingjingwanxiang.cn
HARBOR_USERNAME=replace_me
HARBOR_PASSWORD=replace_me
HARBOR_PROJECT=ci
HARBOR_TLS_VERIFY=true

# Skopeo
SKOPEO_BIN=/usr/bin/skopeo
SKOPEO_TIMEOUT_SECONDS=600

# Worker
WORKER_POLL_SECONDS=3
MAX_RETRIES=6
RETRY_BASE_SECONDS=10
RETRY_MAX_SECONDS=600

# Deploy Auto PR (optional)
DEPLOY_AUTOPR_ENABLED=false
DEPLOY_AUTOPR_GITHUB_TOKEN=replace_me
DEPLOY_AUTOPR_TIMEOUT_SECONDS=10
DEPLOY_AUTOPR_BRANCH_PREFIX=sync
DEPLOY_REPO_OWNER=BrunoGaoSZ
DEPLOY_REPO_NAME=ljwx-deploy
DEPLOY_REPO_BASE_BRANCH=main
DEPLOY_REPO_FILE_PATH=apps/ljwx-platform/overlays/prod/kustomization.yaml
