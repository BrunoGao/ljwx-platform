    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(docker run *)",
      "Bash(docker exec *)",
      "Bash(npx *)",
      "Bash(eval *)",
      "Bash(sh -c *)",
      "WebSearch"
    ]
  },
  "sandbox": {
    "enabled": true,
    "mode": "auto-allow"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
