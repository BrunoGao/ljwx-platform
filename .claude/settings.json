      "Bash(mvn verify -f *)",
      "Bash(mvn dependency:tree -f *)",
      "Bash(mvn versions:display-dependency-updates -f *)",
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm run *)",
      "Bash(pnpm list *)",
      "Bash(pnpm exec *)",
      "Bash(node --version)",
      "Bash(java -version)",
      "Bash(java --version)",
      "Bash(bash scripts/gates/gate-all.sh)",
      "Bash(bash scripts/gates/gate-compile.sh)",
      "Bash(bash scripts/gates/gate-integration.sh)",
      "Bash(bash scripts/gates/gate-manifest.sh)",
      "Bash(bash scripts/gates/gate-contract.sh)",
      "Bash(bash scripts/gates/gate-nfr.sh)",
      "Bash(bash scripts/preflight/preflight-check.sh)",
      "Bash(bash scripts/phase-execute.sh *)",
      "Bash(bash scripts/phase-bundle.sh *)",
      "Bash(bash scripts/phase-parallel.sh *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(grep -r *)",
      "Bash(grep -rn *)",
      "Bash(find *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x scripts/*)",
      "Bash(wc -l *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git commit -m *)",
      "Bash(git status)",
      "Bash(git status --porcelain)",
      "Bash(git diff)",
      "Bash(git diff --name-only *)",
      "Bash(git diff --cached *)",
      "Bash(git diff HEAD *)",
      "Bash(git log --oneline *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git checkout *)",
      "Bash(git merge --no-ff *)",
      "Bash(git worktree add *)",
      "Bash(git worktree remove *)",
      "Bash(git worktree list)",
      "Bash(docker compose -f docker-compose.yml up -d)",
      "Bash(docker compose -f docker-compose.yml down)",
      "Bash(docker compose -f docker-compose.yml ps)",
      "Bash(docker compose -f docker-compose.yml logs *)",
      "Task(backend-builder)",
      "Task(frontend-builder)",
      "Task(code-reviewer)"
