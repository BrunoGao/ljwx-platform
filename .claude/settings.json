{
  "permissions": {
    "defaultMode": "dontAsk",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(docker run *)",
      "Bash(docker exec *)",
      "Bash(npx *)",
      "Bash(eval *)",
      "Bash(sh -c *)",
      "WebSearch",
      "WebFetch",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(secrets/**)"
    ],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Bash(git -C /root/codes/ljwx-deploy *)",
      "Bash(mvn clean compile -f *)",
      "Bash(mvn test -f *)",
      "Bash(mvn verify -f *)",
      "Bash(mvn dependency:tree -f *)",
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm run *)",
      "Bash(pnpm list *)",
      "Bash(pnpm exec *)",
      "Bash(node --version)",
      "Bash(java -version)",
      "Bash(java --version)",
      "Bash(bash scripts/gates/gate-all.sh *)",
      "Bash(bash scripts/gates/gate-compile.sh)",
      "Bash(bash scripts/gates/gate-integration.sh)",
      "Bash(bash scripts/gates/gate-manifest.sh)",
      "Bash(bash scripts/gates/gate-contract.sh)",
      "Bash(bash scripts/gates/gate-nfr.sh)",
      "Bash(bash scripts/preflight/preflight-check.sh)",
      "Bash(bash scripts/review/diff-review.sh *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(grep -r *)",
      "Bash(grep -rn *)",
      "Bash(find *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x scripts/*)",
      "Bash(wc -l *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(sed *)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git commit -m *)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git status --porcelain)",
      "Bash(git diff)",
      "Bash(git diff --name-only *)",
      "Bash(git diff --cached *)",
      "Bash(git diff HEAD *)",
      "Bash(git log --oneline *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git checkout *)",
      "Bash(git merge --no-ff *)",
      "Bash(git worktree add *)",
      "Bash(git worktree remove *)",
      "Bash(git worktree list)",
      "Bash(docker compose -f docker-compose.yml up -d)",
      "Bash(docker compose -f docker-compose.yml down)",
      "Bash(docker compose -f docker-compose.yml ps)",
      "Bash(docker compose -f docker-compose.yml logs *)",
      "Task(backend-builder)",
      "Task(frontend-builder)",
      "Task(code-reviewer)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "mode": "auto-allow",
    "autoAllowBashIfSandboxed": false
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/hooks/pre-edit-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/hooks/post-edit-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/hooks/stop-gate.sh"
          }
        ]
      }
    ]
  }
}
