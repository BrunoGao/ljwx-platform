{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["generated_at", "repo", "totals", "phases", "history"],
  "properties": {
    "generated_at": {"type": "string"},
    "repo": {
      "type": "object",
      "required": ["owner", "name", "branch", "commit"],
      "properties": {
        "owner": {"type": "string"},
        "name": {"type": "string"},
        "branch": {"type": "string"},
        "commit": {"type": "string"}
      }
    },
    "totals": {
      "type": "object",
      "required": ["pass", "fail", "pending", "critical", "warnings"],
      "properties": {
        "pass": {"type": "integer", "minimum": 0},
        "fail": {"type": "integer", "minimum": 0},
        "pending": {"type": "integer", "minimum": 0},
        "critical": {"type": "integer", "minimum": 0},
        "warnings": {"type": "integer", "minimum": 0}
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "status", "pass_rate", "critical", "warnings", "timestamp", "git_commit"],
        "properties": {
          "phase": {"type": "string", "pattern": "^[0-9]{2}$"},
          "status": {"type": "string", "enum": ["PASS", "FAIL", "PENDING"]},
          "pass_rate": {"type": "number", "minimum": 0, "maximum": 100},
          "critical": {"type": "integer", "minimum": 0},
          "warnings": {"type": "integer", "minimum": 0},
          "timestamp": {"type": "string"},
          "git_commit": {"type": "string"}
        }
      }
    },
    "history": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["timestamp", "phase", "status", "pass_rate", "git_commit", "critical", "warnings"],
        "properties": {
          "timestamp": {"type": "string"},
          "phase": {"type": "string", "pattern": "^[0-9]{2}$"},
          "status": {"type": "string", "enum": ["PASS", "FAIL", "PENDING"]},
          "pass_rate": {"type": "number", "minimum": 0, "maximum": 100},
          "git_commit": {"type": "string"},
          "critical": {"type": "integer", "minimum": 0},
          "warnings": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
