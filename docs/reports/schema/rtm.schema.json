{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["generated_at", "matrix", "missing_files"],
  "properties": {
    "generated_at": {"type": "string"},
    "matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "requirement_id", "endpoint", "method", "controller", "service", "test", "test_covered", "spec", "gate_status"],
        "properties": {
          "phase": {"type": ["string", "null"]},
          "requirement_id": {"type": ["string", "null"]},
          "endpoint": {"type": ["string", "null"]},
          "method": {"type": ["string", "null"]},
          "controller": {"type": ["string", "null"]},
          "service": {"type": ["string", "null"]},
          "test": {"type": ["string", "null"]},
          "test_covered": {"type": "boolean"},
          "spec": {"type": ["string", "null"]},
          "gate_status": {"type": "string", "enum": ["PASS", "FAIL", "PENDING"]}
        }
      }
    },
    "missing_files": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
